# Optional local ports
PARTCOPY_API_PORT=3002

# Security: API Key (set same value for server and client)
PARTCOPY_API_KEY=your-secret-api-key
VITE_PARTCOPY_API_KEY=your-secret-api-key

# Supabase Local (supabase start で取得)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
